  "description": "Support Flow is a platform for managing support requests and tickets",
  "main": "server.js",
  "scripts": {
    "test": "node --test",
     "start": "npm install --production && node server.js",
    "start-watch": "nodemon --legacy-watch --inspect --watch server.js --watch src --ext js,mjs,cjs,json server.js",
    "dev": "nodemon --legacy-watch --watch server.js --watch src --ext js,mjs,cjs,json server.js",
    "lint": "eslint .",
    "email:verify": "node scripts/verify-email.js"
  },
  "keywords": [
