NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
WEB_URL=http://localhost:5173

# Database
DB_URL=mongodb://localhost:27017/supportflow

# JWT
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_different_long_random_refresh_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google login
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# BullMQ email queue
# Use an ioredis-compatible URL. For Upstash, prefer the rediss:// endpoint.
UPSTASH_REDIS_URL=rediss://default:password@host.upstash.io:6379
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=1000
REDIS_COMMAND_TIMEOUT_MS=1000

# Email SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_FROM="SupportFlow AI <your_email@gmail.com>"
EMAIL_MAX_CONNECTIONS=5
EMAIL_MAX_MESSAGES=100
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Optional Upstash REST cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
